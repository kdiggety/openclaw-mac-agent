#!/usr/bin/env python3
import argparse
import json
import os
import platform
import re
import shutil
import subprocess
import sys
import time
import uuid
from datetime import datetime, timezone
from pathlib import Path
from typing import Any, Dict, List, Optional, Tuple


BASE_DIR = Path(__file__).resolve().parents[1]
AGENT_REPO_ROOT = BASE_DIR.parents[1]
DEFAULT_CONFIG = BASE_DIR / "config" / "repos.json"
DEFAULT_CONFIG_EXAMPLE = BASE_DIR / "config" / "repos.example.json"
DEFAULT_AGENT_HOME = Path.home() / ".openclaw-mac-agent"
PATH_ENV = "/usr/bin:/bin:/usr/sbin:/sbin:/opt/homebrew/bin"
MAX_STDOUT_BYTES = 32768
MAX_STDERR_BYTES = 32768
MAX_COMBINED_BYTES = 65536
MAX_READ_BYTES = 65536
MAX_TAIL_LINES = 500
MAX_LIST_ITEMS = 500
PUBLIC_VERBS = {
    "env-check",
    "repo-status",
    "resolve-sources",
    "read-file",
    "tail-file",
    "list-artifacts",
    "summarize-artifact",
    "validate-analyzer",
    "validate-masterofdrums-chart",
    "run-pipeline",
    "get-run-status",
    "git-fetch",
    "git-pull",
    "git-sync",
}
TEXT_EXTENSIONS = {
    ".json",
    ".txt",
    ".log",
    ".md",
    ".csv",
    ".yaml",
    ".yml",
    ".swift",
    ".py",
    ".sh",
}
MASTEROFDRUMS_VALIDATION_MODES = {
    "build-only",
    "import-timing",
    "manual-override",
    "mismatch-diagnostic",
    "full",
}


class AgentError(Exception):
    def __init__(self, code: str, message: str, exit_code: int = 22, details: Optional[Dict[str, Any]] = None):
        super().__init__(message)
        self.code = code
        self.message = message
        self.exit_code = exit_code
        self.details = details or {}


def utc_now() -> str:
    return datetime.now(timezone.utc).strftime("%Y-%m-%dT%H:%M:%SZ")


def make_request_id() -> str:
    return f"{datetime.now(timezone.utc).strftime('%Y%m%d-%H%M%S')}-{uuid.uuid4().hex[:8]}"


def truncate_text(text: str, limit: int) -> Tuple[str, bool, int]:
    encoded = text.encode("utf-8", errors="replace")
    if len(encoded) <= limit:
        return text, False, len(encoded)
    trimmed = encoded[:limit].decode("utf-8", errors="replace")
    return trimmed, True, len(encoded)


def load_config(config_path: Optional[str]) -> Dict[str, Any]:
    if config_path:
        path = Path(config_path).expanduser()
    elif DEFAULT_CONFIG.exists():
        path = DEFAULT_CONFIG
    else:
        path = DEFAULT_CONFIG_EXAMPLE

    if not path.exists():
        raise AgentError("CONFIG_MISSING", f"Config file not found: {path}", 22)

    with path.open("r", encoding="utf-8") as handle:
        payload = json.load(handle)
    payload["_config_path"] = str(path)
    return payload


def ensure_agent_home(agent_home: Path) -> None:
    (agent_home / "logs").mkdir(parents=True, exist_ok=True)


def audit_log(agent_home: Path, record: Dict[str, Any]) -> None:
    ensure_agent_home(agent_home)
    with (agent_home / "logs" / "audit.log").open("a", encoding="utf-8") as handle:
        handle.write(json.dumps(record, separators=(",", ":")))
        handle.write("\n")


def response_envelope(
    *,
    ok: bool,
    verb: str,
    request_id: str,
    exit_code: int,
    started_at: float,
    data: Any = None,
    stdout: str = "",
    stderr: str = "",
    warnings: Optional[List[Any]] = None,
    error: Optional[Dict[str, Any]] = None,
    truncation: Optional[Dict[str, Any]] = None,
) -> Dict[str, Any]:
    duration_ms = int((time.time() - started_at) * 1000)
    payload = {
        "ok": ok,
        "verb": verb,
        "request_id": request_id,
        "exit_code": exit_code,
        "duration_ms": duration_ms,
        "truncated": bool(truncation and (truncation.get("stdout_truncated") or truncation.get("stderr_truncated"))),
        "stdout": stdout,
        "stderr": stderr,
        "data": data,
        "warnings": warnings or [],
        "error": error,
    }
    payload["limits"] = {
        "max_stdout_bytes": MAX_STDOUT_BYTES,
        "max_stderr_bytes": MAX_STDERR_BYTES,
        "max_combined_bytes": MAX_COMBINED_BYTES,
    }
    payload["truncation"] = truncation or {
        "stdout_truncated": False,
        "stderr_truncated": False,
        "stdout_original_bytes": len(stdout.encode("utf-8")),
        "stderr_original_bytes": len(stderr.encode("utf-8")),
    }
    return payload


def emit_json(payload: Dict[str, Any]) -> None:
    print(json.dumps(payload, separators=(",", ":")))


def parse_repo(config: Dict[str, Any], repo_name: str) -> Dict[str, Any]:
    repos = config.get("repos") or {}
    if repo_name not in repos:
        raise AgentError("UNKNOWN_REPO", f"Unknown repo: {repo_name}", 22, {"repo": repo_name})
    repo_config = repos[repo_name]
    repo_path = Path(repo_config["path"]).expanduser().resolve()
    if not repo_path.exists():
        raise AgentError("REPO_MISSING", f"Repo path not found: {repo_path}", 22, {"repo": repo_name, "path": str(repo_path)})

    roots_template = {
        "repo": "{repo}",
        "logs": "{repo}/logs",
        "artifacts": "{repo}/output",
        "tmp": "{repo}/tmp",
        "runs": "{repo}/runs",
    }
    roots_template.update(config.get("roots") or {})
    roots_template.update(repo_config.get("roots") or {})

    roots: Dict[str, Path] = {}
    for name, template in roots_template.items():
        roots[name] = Path(str(template).format(repo=str(repo_path))).expanduser().resolve()

    return {
        "name": repo_name,
        "path": repo_path,
        "config": repo_config,
        "roots": roots,
    }


def ensure_relative_path(path_value: str) -> Path:
    path = Path(path_value)
    if path.is_absolute():
        raise AgentError("ABSOLUTE_PATH_REJECTED", "Absolute paths are not allowed", 22, {"path": path_value})
    if not path.parts:
        raise AgentError("EMPTY_PATH", "Path must not be empty", 22)
    if any(part == ".." for part in path.parts):
        raise AgentError("PARENT_PATH_REJECTED", "Parent path traversal is not allowed", 22, {"path": path_value})
    return path


def ensure_within_root(root: Path, candidate: Path) -> Path:
    resolved = candidate.resolve()
    try:
        if os.path.commonpath([str(root), str(resolved)]) != str(root):
            raise AgentError("PATH_OUTSIDE_ALLOWED_ROOT", "Resolved path is outside approved root", 22, {"root": str(root), "path": str(resolved)})
    except ValueError:
        raise AgentError("PATH_OUTSIDE_ALLOWED_ROOT", "Resolved path is outside approved root", 22, {"root": str(root), "path": str(resolved)})
    return resolved


def resolve_root(repo_info: Dict[str, Any], root_name: str) -> Path:
    roots = repo_info["roots"]
    if root_name not in roots:
        raise AgentError("UNKNOWN_ROOT", f"Unknown root: {root_name}", 22, {"root": root_name})
    return roots[root_name]


def resolve_repo_path(repo_info: Dict[str, Any], root_name: str, relative_path: str, must_exist: bool = True) -> Path:
    root = resolve_root(repo_info, root_name)
    rel = ensure_relative_path(relative_path)
    candidate = root / rel
    if must_exist and not candidate.exists():
        raise AgentError("PATH_NOT_FOUND", f"Path not found: {candidate}", 22, {"path": relative_path, "root": root_name})
    if must_exist:
        return ensure_within_root(root, candidate)
    return ensure_within_root(root, candidate.parent) / candidate.name


def file_is_text(path: Path) -> bool:
    if path.suffix.lower() in TEXT_EXTENSIONS:
        return True
    with path.open("rb") as handle:
        sample = handle.read(1024)
    return b"\x00" not in sample


def runtime_dirs(repo_info: Dict[str, Any], run_dir: Optional[Path] = None) -> Dict[str, Path]:
    base_dir = run_dir or repo_info["roots"]["tmp"]
    tmp_dir = base_dir / "tmp" if run_dir else repo_info["roots"]["tmp"]
    home_dir = base_dir / "home"
    cache_dir = base_dir / "cache"
    clang_cache_dir = cache_dir / "clang" / "ModuleCache"
    swiftpm_cache_dir = home_dir / "Library" / "Caches" / "org.swift.swiftpm"
    swiftpm_config_dir = home_dir / "Library" / "org.swift.swiftpm" / "configuration"
    swiftpm_security_dir = home_dir / "Library" / "org.swift.swiftpm" / "security"
    for path in (tmp_dir, home_dir, cache_dir, clang_cache_dir, swiftpm_cache_dir, swiftpm_config_dir, swiftpm_security_dir):
        path.mkdir(parents=True, exist_ok=True)
    return {
        "base": base_dir,
        "tmp": tmp_dir,
        "home": home_dir,
        "cache": cache_dir,
        "clang_cache": clang_cache_dir,
        "swiftpm_cache": swiftpm_cache_dir,
        "swiftpm_config": swiftpm_config_dir,
        "swiftpm_security": swiftpm_security_dir,
    }


def build_env(repo_info: Dict[str, Any], run_dir: Optional[Path] = None, extra_env: Optional[Dict[str, str]] = None) -> Dict[str, str]:
    dirs = runtime_dirs(repo_info, run_dir)
    env = {
        "HOME": str(dirs["home"]),
        "USER": os.environ.get("USER", ""),
        "LOGNAME": os.environ.get("LOGNAME", ""),
        "PATH": PATH_ENV,
        "TMPDIR": str(dirs["tmp"]),
        "XDG_CACHE_HOME": str(dirs["cache"]),
        "CLANG_MODULE_CACHE_PATH": str(dirs["clang_cache"]),
        "PYTHONUNBUFFERED": "1",
    }
    if run_dir:
        env["OPENCLAW_RUN_DIR"] = str(run_dir)
    if extra_env:
        env.update(extra_env)
    return env


def resolve_executable(argv0: str, repo_info: Dict[str, Any]) -> Path:
    candidate = Path(argv0)
    if candidate.is_absolute():
        resolved = candidate.resolve()
    else:
        which = shutil.which(argv0, path=PATH_ENV)
        if which is None:
            raise AgentError("BINARY_NOT_FOUND", f"Executable not found: {argv0}", 22, {"argv0": argv0})
        resolved = Path(which).resolve()

    allowed = {
        Path("/usr/bin/env"),
        Path("/usr/bin/xcrun"),
        Path("/usr/bin/xcode-select"),
        Path("/usr/bin/git"),
        Path("/usr/bin/python3"),
        Path("/opt/homebrew/bin/python3"),
        Path("/usr/bin/swift"),
        Path("/opt/homebrew/bin/ffmpeg"),
        Path("/opt/homebrew/bin/ffprobe"),
    }
    allowed_prefixes = (
        Path("/opt/homebrew/Cellar"),
        Path("/opt/homebrew/bin"),
    )
    repo_path = repo_info["path"]
    venv_python = (repo_path / ".venv" / "bin" / "python").resolve() if (repo_path / ".venv" / "bin" / "python").exists() else None

    if resolved in allowed:
        return resolved
    for prefix in allowed_prefixes:
        try:
            if os.path.commonpath([str(prefix), str(resolved)]) == str(prefix):
                return resolved
        except ValueError:
            pass
    if venv_python and resolved == venv_python:
        return resolved
    try:
        if os.path.commonpath([str(repo_path), str(resolved)]) == str(repo_path):
            return resolved
    except ValueError:
        pass
    raise AgentError("BINARY_NOT_ALLOWED", f"Executable is not allowlisted: {resolved}", 22, {"argv0": argv0, "resolved": str(resolved)})


def run_subprocess(
    argv: List[str],
    *,
    repo_info: Dict[str, Any],
    cwd: Optional[Path] = None,
    timeout: int,
    run_dir: Optional[Path] = None,
    extra_env: Optional[Dict[str, str]] = None,
) -> Dict[str, Any]:
    executable = resolve_executable(argv[0], repo_info)
    argv = [str(executable), *argv[1:]]
    cwd = cwd or repo_info["path"]
    env = build_env(repo_info, run_dir, extra_env)
    try:
        completed = subprocess.run(
            argv,
            cwd=str(cwd),
            env=env,
            capture_output=True,
            text=True,
            timeout=timeout,
            check=False,
        )
    except subprocess.TimeoutExpired as exc:
        raise AgentError("TIMEOUT", "Command exceeded timeout", 124, {"timeout_seconds": timeout, "argv": argv, "stdout": exc.stdout or "", "stderr": exc.stderr or ""})

    combined = (completed.stdout or "") + (completed.stderr or "")
    stdout_text, stdout_truncated, stdout_original = truncate_text(completed.stdout or "", MAX_STDOUT_BYTES)
    stderr_text, stderr_truncated, stderr_original = truncate_text(completed.stderr or "", MAX_STDERR_BYTES)
    if len(combined.encode("utf-8", errors="replace")) > MAX_COMBINED_BYTES:
        overflow = len(combined.encode("utf-8", errors="replace")) - MAX_COMBINED_BYTES
        if not stderr_truncated:
            stderr_text = truncate_text(stderr_text, max(0, len(stderr_text.encode("utf-8")) - overflow))[0]
            stderr_truncated = True

    return {
        "argv": argv,
        "status": completed.returncode,
        "stdout": stdout_text,
        "stderr": stderr_text,
        "truncation": {
            "stdout_truncated": stdout_truncated,
            "stderr_truncated": stderr_truncated,
            "stdout_original_bytes": stdout_original,
            "stderr_original_bytes": stderr_original,
        },
    }


def repo_status_lines(repo_info: Dict[str, Any]) -> List[str]:
    result = run_subprocess(["git", "status", "--short"], repo_info=repo_info, timeout=10)
    lines = [line for line in result["stdout"].splitlines() if line.strip()]
    return lines[:200]


def git_head(repo_info: Dict[str, Any]) -> str:
    result = run_subprocess(["git", "rev-parse", "HEAD"], repo_info=repo_info, timeout=10)
    return result["stdout"].strip()


def validate_branch_name(branch: str) -> None:
    if not branch or not re.fullmatch(r"[A-Za-z0-9._/-]+", branch):
        raise AgentError("INVALID_BRANCH", f"Invalid branch name: {branch}", 22, {"branch": branch})
    if branch.startswith("/") or branch.endswith("/") or ".." in branch or "@{" in branch or "\\" in branch:
        raise AgentError("INVALID_BRANCH", f"Invalid branch name: {branch}", 22, {"branch": branch})


def validate_commit_sha(commit: str) -> None:
    if not re.fullmatch(r"[0-9a-fA-F]{7,40}", commit):
        raise AgentError("INVALID_COMMIT", f"Invalid commit SHA: {commit}", 22, {"expected_commit": commit})


def validate_validation_mode(mode: str) -> None:
    if mode not in MASTEROFDRUMS_VALIDATION_MODES:
        raise AgentError("INVALID_VALIDATION_MODE", f"Invalid validation mode: {mode}", 22, {"validation_mode": mode})


def parse_time_signature(value: str) -> Dict[str, int]:
    match = re.fullmatch(r"(\d{1,3})/(\d{1,3})", value)
    if not match:
        raise AgentError("INVALID_TIME_SIGNATURE", f"Invalid time signature: {value}", 22, {"expected_time_signature": value})
    numerator = int(match.group(1))
    denominator = int(match.group(2))
    if numerator <= 0 or denominator <= 0:
        raise AgentError("INVALID_TIME_SIGNATURE", f"Invalid time signature: {value}", 22, {"expected_time_signature": value})
    return {"numerator": numerator, "denominator": denominator}


def parse_summary_artifacts(run_dir: Path) -> List[Dict[str, Any]]:
    summary_path = run_dir / "artifacts" / "summary.json"
    if not summary_path.exists():
        return []
    try:
        payload = json.loads(summary_path.read_text(encoding="utf-8"))
    except json.JSONDecodeError:
        return []
    items = payload.get("artifacts")
    return items if isinstance(items, list) else []


def handler_env_check(args: argparse.Namespace, config: Dict[str, Any], repo_info: Dict[str, Any]) -> Dict[str, Any]:
    tools = {}
    for label, argv in (
        ("xcode_select", ["xcode-select", "-p"]),
        ("swift", ["swift", "--version"]),
        ("python3", ["python3", "--version"]),
        ("git", ["git", "--version"]),
    ):
        try:
            result = run_subprocess(argv, repo_info=repo_info, timeout=10)
            tools[label] = {"ok": result["status"] == 0, "version": (result["stdout"] or result["stderr"]).strip()}
        except AgentError as exc:
            tools[label] = {"ok": False, "error": exc.message}

    ffmpeg_path = shutil.which("ffmpeg", path=PATH_ENV)
    if ffmpeg_path:
        ffmpeg_result = run_subprocess(["ffmpeg", "-version"], repo_info=repo_info, timeout=10)
        tools["ffmpeg"] = {"ok": ffmpeg_result["status"] == 0, "version": (ffmpeg_result["stdout"] or ffmpeg_result["stderr"]).splitlines()[0] if (ffmpeg_result["stdout"] or ffmpeg_result["stderr"]) else ""}
    else:
        tools["ffmpeg"] = {"ok": False, "error": "ffmpeg not found"}

    venv_python = repo_info["path"] / ".venv" / "bin" / "python"
    if venv_python.exists():
        venv_result = run_subprocess([str(venv_python), "--version"], repo_info=repo_info, timeout=10)
        tools["repo_venv_python"] = {
            "ok": venv_result["status"] == 0,
            "path": str(venv_python),
            "version": (venv_result["stdout"] or venv_result["stderr"]).strip(),
        }
    else:
        tools["repo_venv_python"] = {"ok": False, "path": str(venv_python), "error": "venv missing"}

    return {
        "repo": {"name": repo_info["name"], "path": str(repo_info["path"]), "exists": True},
        "platform": {"os": "macOS", "version": platform.mac_ver()[0], "arch": platform.machine()},
        "tools": tools,
        "roots": {name: str(path) for name, path in repo_info["roots"].items()},
        "config_path": config["_config_path"],
    }


def handler_repo_status(args: argparse.Namespace, config: Dict[str, Any], repo_info: Dict[str, Any]) -> Dict[str, Any]:
    branch = run_subprocess(["git", "branch", "--show-current"], repo_info=repo_info, timeout=10)
    head = run_subprocess(["git", "rev-parse", "HEAD"], repo_info=repo_info, timeout=10)
    status_lines = repo_status_lines(repo_info)
    remote = run_subprocess(["git", "remote", "-v"], repo_info=repo_info, timeout=10)
    return {
        "repo": {"name": repo_info["name"], "path": str(repo_info["path"])},
        "git": {
            "branch": branch["stdout"].strip(),
            "head": head["stdout"].strip(),
            "is_dirty": bool(status_lines),
            "changed_files": len([line for line in status_lines if not line.startswith("??")]),
            "untracked_files": len([line for line in status_lines if line.startswith("??")]),
            "status_short": status_lines,
            "remotes": remote["stdout"].splitlines(),
        },
        "paths": {
            "venv_exists": (repo_info["path"] / ".venv").exists(),
            "logs_dir_exists": repo_info["roots"]["logs"].exists(),
            "artifacts_dir_exists": repo_info["roots"]["artifacts"].exists(),
            "runs_dir_exists": repo_info["roots"]["runs"].exists(),
        },
    }


def handler_read_file(args: argparse.Namespace, config: Dict[str, Any], repo_info: Dict[str, Any]) -> Dict[str, Any]:
    max_bytes = min(args.max_bytes, MAX_READ_BYTES)
    path = resolve_repo_path(repo_info, args.root, args.path, must_exist=True)
    if not path.is_file():
        raise AgentError("NOT_A_FILE", f"Path is not a file: {path}", 22)
    if not file_is_text(path):
        raise AgentError("BINARY_FILE_REJECTED", "Binary files are not supported in v1", 22, {"path": str(path)})
    content = path.read_text(encoding="utf-8", errors="replace")
    content_text, truncated, original_bytes = truncate_text(content, max_bytes)
    return {
        "file": {
            "root": args.root,
            "relative_path": args.path,
            "resolved_path": str(path),
            "size_bytes": path.stat().st_size,
            "mtime": datetime.fromtimestamp(path.stat().st_mtime, tz=timezone.utc).strftime("%Y-%m-%dT%H:%M:%SZ"),
            "content_type": "text/plain",
            "encoding": "utf-8",
            "truncated": truncated,
            "original_bytes": original_bytes,
        },
        "content": content_text,
    }


def handler_tail_file(args: argparse.Namespace, config: Dict[str, Any], repo_info: Dict[str, Any]) -> Dict[str, Any]:
    lines_requested = min(args.lines, MAX_TAIL_LINES)
    path = resolve_repo_path(repo_info, args.root, args.path, must_exist=True)
    if not path.is_file():
        raise AgentError("NOT_A_FILE", f"Path is not a file: {path}", 22)
    if not file_is_text(path):
        raise AgentError("BINARY_FILE_REJECTED", "Binary files are not supported in v1", 22, {"path": str(path)})
    lines = path.read_text(encoding="utf-8", errors="replace").splitlines()
    selected = lines[-lines_requested:]
    text = "\n".join(selected)
    tail_text, truncated, original_bytes = truncate_text(text, MAX_READ_BYTES)
    return {
        "file": {
            "root": args.root,
            "relative_path": args.path,
            "resolved_path": str(path),
            "size_bytes": path.stat().st_size,
            "mtime": datetime.fromtimestamp(path.stat().st_mtime, tz=timezone.utc).strftime("%Y-%m-%dT%H:%M:%SZ"),
        },
        "tail": {
            "requested_lines": lines_requested,
            "returned_lines": len(selected),
            "text": tail_text,
            "truncated": truncated,
            "original_bytes": original_bytes,
        },
    }


def handler_list_artifacts(args: argparse.Namespace, config: Dict[str, Any], repo_info: Dict[str, Any]) -> Dict[str, Any]:
    root = resolve_root(repo_info, args.root)
    base = root
    if args.path:
        base = resolve_repo_path(repo_info, args.root, args.path, must_exist=False)
    if not base.exists():
        return {"artifacts_root": str(base), "items": []}

    items: List[Dict[str, Any]] = []
    if base.is_file():
        rel = base.relative_to(root)
        items.append({
            "path": str(rel),
            "size_bytes": base.stat().st_size,
            "mtime": datetime.fromtimestamp(base.stat().st_mtime, tz=timezone.utc).strftime("%Y-%m-%dT%H:%M:%SZ"),
            "kind": base.suffix.lower().lstrip(".") or "file",
        })
    else:
        for path in sorted(base.rglob("*"), key=lambda item: item.stat().st_mtime if item.exists() else 0, reverse=True):
            if len(items) >= MAX_LIST_ITEMS:
                break
            if not path.is_file():
                continue
            rel = path.relative_to(root)
            items.append({
                "path": str(rel),
                "size_bytes": path.stat().st_size,
                "mtime": datetime.fromtimestamp(path.stat().st_mtime, tz=timezone.utc).strftime("%Y-%m-%dT%H:%M:%SZ"),
                "kind": path.suffix.lower().lstrip(".") or "file",
            })
    return {"artifacts_root": str(root), "items": items}


def summarize_json(path: Path) -> Dict[str, Any]:
    payload = json.loads(path.read_text(encoding="utf-8"))
    summary: Dict[str, Any] = {"top_level_type": type(payload).__name__.lower()}
    if isinstance(payload, dict):
        summary["top_level_keys"] = list(payload.keys())[:50]
        for key in ("events", "tempo_map", "songs", "items"):
            if key in payload and isinstance(payload[key], list):
                summary[f"{key}_count"] = len(payload[key])
    elif isinstance(payload, list):
        summary["length"] = len(payload)
    return summary


def summarize_csv(path: Path) -> Dict[str, Any]:
    lines = path.read_text(encoding="utf-8", errors="replace").splitlines()
    header = lines[0].split(",") if lines else []
    return {"rows": max(0, len(lines) - 1), "cols": len(header), "header": header[:50]}


def summarize_text(path: Path) -> Dict[str, Any]:
    lines = path.read_text(encoding="utf-8", errors="replace").splitlines()
    return {
        "line_count": len(lines),
        "head": "\n".join(lines[:10]),
        "tail": "\n".join(lines[-10:]),
    }


def handler_summarize_artifact(args: argparse.Namespace, config: Dict[str, Any], repo_info: Dict[str, Any]) -> Dict[str, Any]:
    root_name = args.root or "repo"
    path = resolve_repo_path(repo_info, root_name, args.path, must_exist=True)
    if path.suffix.lower() == ".json":
        summary = summarize_json(path)
        kind = "json"
    elif path.suffix.lower() == ".csv":
        summary = summarize_csv(path)
        kind = "csv"
    else:
        if not file_is_text(path):
            raise AgentError("BINARY_FILE_REJECTED", "Binary artifacts are not summarized in v1", 22, {"path": str(path)})
        summary = summarize_text(path)
        kind = "text"
    return {
        "artifact": {
            "path": args.path,
            "resolved_path": str(path),
            "kind": kind,
            "size_bytes": path.stat().st_size,
        },
        "summary": summary,
    }


def ensure_file_uri(source_uri: str) -> Path:
    if not source_uri.startswith("file://"):
        raise AgentError("UNSUPPORTED_SOURCE_URI", "Only file:// URIs are supported in v1", 22, {"source_uri": source_uri})
    path = Path(source_uri[7:])
    if not path.exists():
        raise AgentError("SOURCE_NOT_FOUND", f"Source file not found: {path}", 22, {"source_uri": source_uri})
    return path.resolve()


def resolve_source_entries(
    repo_info: Dict[str, Any],
    *,
    source_uri: Optional[str],
    source_name: Optional[str],
    sample_set: Optional[str],
    profile: Optional[Dict[str, Any]] = None,
) -> List[Dict[str, Any]]:
    repo_cfg = repo_info["config"]
    sample_sources = repo_cfg.get("sample_sources") or {}
    sample_sets = repo_cfg.get("sample_sets") or {}

    if sum(1 for value in (source_uri, source_name, sample_set) if value) > 1:
        raise AgentError("SOURCE_SELECTOR_CONFLICT", "Set only one of source-uri, source-name, or sample-set", 22)

    def direct_source(uri: str) -> Dict[str, Any]:
        return {"source_name": None, "source_uri": uri, "source_path": str(ensure_file_uri(uri))}

    def named_source(name: str) -> Dict[str, Any]:
        if name not in sample_sources:
            raise AgentError("UNKNOWN_SAMPLE_SOURCE", f"Unknown sample source: {name}", 22, {"source_name": name})
        uri = sample_sources[name]
        return {"source_name": name, "source_uri": uri, "source_path": str(ensure_file_uri(uri))}

    def named_set(name: str) -> List[Dict[str, Any]]:
        if name not in sample_sets:
            raise AgentError("UNKNOWN_SAMPLE_SET", f"Unknown sample set: {name}", 22, {"sample_set": name})
        entries = sample_sets[name]
        if not isinstance(entries, list) or not entries:
            raise AgentError("EMPTY_SAMPLE_SET", f"Sample set is empty: {name}", 22, {"sample_set": name})
        resolved: List[Dict[str, Any]] = []
        for item in entries:
            if not isinstance(item, str):
                raise AgentError("INVALID_SAMPLE_SET", f"Sample set entries must be strings: {name}", 22, {"sample_set": name})
            resolved.append(direct_source(item) if item.startswith("file://") else named_source(item))
        return resolved

    if source_uri:
        return [direct_source(source_uri)]
    if source_name:
        return [named_source(source_name)]
    if sample_set:
        return named_set(sample_set)
    if profile:
        default_sample_set = profile.get("default_sample_set")
        if default_sample_set:
            return named_set(default_sample_set)
        default_source_uri = profile.get("default_source_uri")
        if default_source_uri:
            return [direct_source(default_source_uri)]
        default_source_name = profile.get("default_source_name")
        if default_source_name:
            return [named_source(default_source_name)]

    raise AgentError(
        "SOURCE_REQUIRED",
        "A source is required; pass --source-uri, --source-name, or --sample-set, or configure a default source in the profile",
        22,
        {"profile": profile.get("name") if profile else None},
    )


def resolve_source_input(
    repo_info: Dict[str, Any],
    *,
    source_uri: Optional[str],
    source_name: Optional[str],
    sample_set: Optional[str],
    profile: Optional[Dict[str, Any]] = None,
) -> Tuple[str, Path, str]:
    entries = resolve_source_entries(
        repo_info,
        source_uri=source_uri,
        source_name=source_name,
        sample_set=sample_set,
        profile=profile,
    )
    if len(entries) != 1:
        raise AgentError(
            "MULTI_SOURCE_REQUIRES_BATCH",
            "Multiple sources resolved; use resolve-sources and run the batch from the wrapper",
            22,
            {"count": len(entries)},
        )
    entry = entries[0]
    return entry["source_uri"], Path(entry["source_path"]), entry.get("source_name") or ""


def render_template_list(items: List[str], repo_info: Dict[str, Any], extra: Optional[Dict[str, str]] = None) -> List[str]:
    mapping = {
        "repo": str(repo_info["path"]),
        "agent_base": str(BASE_DIR),
        "agent_repo": str(AGENT_REPO_ROOT),
        "input": "{input}",
        "output": "{output}",
    }
    mapping.update({f"root_{name}": str(path) for name, path in repo_info["roots"].items()})
    mapping.update(extra or {})
    return [item.format(**mapping) for item in items]


def render_template_map(items: Dict[str, str], repo_info: Dict[str, Any], extra: Optional[Dict[str, str]] = None) -> Dict[str, str]:
    mapping = {
        "repo": str(repo_info["path"]),
        "agent_base": str(BASE_DIR),
        "agent_repo": str(AGENT_REPO_ROOT),
        "input": "{input}",
        "output": "{output}",
    }
    mapping.update({f"root_{name}": str(path) for name, path in repo_info["roots"].items()})
    mapping.update(extra or {})
    return {key: value.format(**mapping) for key, value in items.items()}


def handler_resolve_sources(args: argparse.Namespace, config: Dict[str, Any], repo_info: Dict[str, Any]) -> Dict[str, Any]:
    profile = None
    if getattr(args, "profile", None):
        profiles = (repo_info["config"].get("pipeline_profiles") or {})
        if args.profile not in profiles:
            raise AgentError("UNKNOWN_PROFILE", f"Unknown pipeline profile: {args.profile}", 22, {"profile": args.profile})
        profile = dict(profiles[args.profile])
        profile["name"] = args.profile
    sources = resolve_source_entries(
        repo_info,
        source_uri=getattr(args, "source_uri", None),
        source_name=getattr(args, "source_name", None),
        sample_set=getattr(args, "sample_set", None),
        profile=profile,
    )
    return {
        "repo": repo_info["name"],
        "profile": getattr(args, "profile", None),
        "sources": sources,
    }


def handler_validate_analyzer(args: argparse.Namespace, config: Dict[str, Any], repo_info: Dict[str, Any]) -> Dict[str, Any]:
    venv_python = repo_info["path"] / ".venv" / "bin" / "python"
    repo_cfg = repo_info["config"]
    profile = None
    if getattr(args, "profile", None):
        profiles = (repo_cfg.get("pipeline_profiles") or {})
        if args.profile not in profiles:
            raise AgentError("UNKNOWN_PROFILE", f"Unknown pipeline profile: {args.profile}", 22, {"profile": args.profile})
        profile = dict(profiles[args.profile])
        profile["name"] = args.profile
    logs = []
    source_uri_checked = False
    source_path = None
    resolved_source_uri = ""
    resolved_source_name = ""
    validation = {
        "venv_present": venv_python.exists(),
        "imports_ok": False,
        "config_ok": True,
        "ffmpeg_ok": shutil.which("ffmpeg", path=PATH_ENV) is not None,
        "source_uri_checked": source_uri_checked,
    }

    recipe = (repo_cfg.get("recipes") or {}).get("validate-analyzer")
    if recipe:
        resolved_source_uri, source_path, resolved_source_name = resolve_source_input(
            repo_info,
            source_uri=args.source_uri,
            source_name=getattr(args, "source_name", None),
            sample_set=getattr(args, "sample_set", None),
            profile=profile,
        )
        source_uri_checked = True
        validation["source_uri_checked"] = True
        template_vars = {
            "source_uri": resolved_source_uri,
            "source_path": str(source_path),
            "source_name": resolved_source_name,
        }
        argv = render_template_list(recipe["argv"], repo_info, template_vars)
        recipe_env = render_template_map(recipe.get("env") or {}, repo_info, template_vars)
        timeout = int(recipe.get("timeout_seconds", 60))
        result = run_subprocess(argv, repo_info=repo_info, timeout=timeout, extra_env=recipe_env)
        validation["imports_ok"] = result["status"] == 0
        logs.append({"stdout": result["stdout"], "stderr": result["stderr"]})
        if result["status"] != 0:
            raise AgentError("VALIDATE_ANALYZER_FAILED", "Analyzer validation failed", result["status"], {"stdout": result["stdout"], "stderr": result["stderr"]})
    else:
        validation["imports_ok"] = venv_python.exists() or shutil.which("python3", path=PATH_ENV) is not None

    return {
        "repo": repo_info["name"],
        "validation": validation,
        "source": {
            "source_uri": resolved_source_uri or args.source_uri,
            "source_name": resolved_source_name or getattr(args, "source_name", None),
            "profile": getattr(args, "profile", None),
        },
        "logs": logs,
    }


def run_git_sync(repo_info: Dict[str, Any], branch: str, expected_commit: str) -> Dict[str, Any]:
    validate_branch_name(branch)
    validate_commit_sha(expected_commit)
    ensure_clean_tree(repo_info)

    fetch_result = run_subprocess(["git", "fetch", "--prune", "origin"], repo_info=repo_info, timeout=60)
    remote_ref = f"refs/remotes/origin/{branch}"
    ref_check = run_subprocess(["git", "show-ref", "--verify", remote_ref], repo_info=repo_info, timeout=10)
    if ref_check["status"] != 0:
        raise AgentError("REMOTE_BRANCH_NOT_FOUND", f"Remote branch not found: origin/{branch}", 22, {"branch": branch})

    commit_check = run_subprocess(["git", "rev-parse", "--verify", f"{expected_commit}^{{commit}}"], repo_info=repo_info, timeout=10)
    if commit_check["status"] != 0:
        raise AgentError("COMMIT_NOT_FOUND", f"Commit not found: {expected_commit}", 22, {"expected_commit": expected_commit})
    resolved_commit = commit_check["stdout"].strip()

    ancestry = run_subprocess(["git", "merge-base", "--is-ancestor", resolved_commit, remote_ref], repo_info=repo_info, timeout=10)
    if ancestry["status"] != 0:
        raise AgentError(
            "COMMIT_NOT_ON_BRANCH",
            f"Commit {resolved_commit} is not reachable from origin/{branch}",
            22,
            {"branch": branch, "expected_commit": resolved_commit},
        )

    checkout = run_subprocess(["git", "checkout", "--detach", resolved_commit], repo_info=repo_info, timeout=30)
    final_head = git_head(repo_info)
    return {
        "operation": "sync",
        "branch": branch,
        "expected_commit": expected_commit,
        "resolved_commit": resolved_commit,
        "head": final_head,
        "exit_code": checkout["status"],
        "stdout": "\n".join(part for part in [fetch_result["stdout"], checkout["stdout"]] if part).strip(),
        "stderr": "\n".join(part for part in [fetch_result["stderr"], checkout["stderr"]] if part).strip(),
    }


def parse_json_if_possible(text: str) -> Optional[Any]:
    stripped = text.strip()
    if not stripped:
        return None
    try:
        return json.loads(stripped)
    except json.JSONDecodeError:
        return None


def build_masterofdrums_template_vars(
    repo_info: Dict[str, Any],
    *,
    chart_root: str,
    chart_path: str,
    chart_resolved_path: Path,
    audio_root: Optional[str],
    audio_path: Optional[str],
    audio_resolved_path: Optional[Path],
    validation_mode: str,
    expectations: Dict[str, Any],
) -> Dict[str, str]:
    template_vars = {
        "chart_root": chart_root,
        "chart_path": chart_path,
        "chart_resolved_path": str(chart_resolved_path),
        "validation_mode": validation_mode,
        "expected_bpm": "" if expectations.get("bpm") is None else str(expectations["bpm"]),
        "expected_offset_seconds": "" if expectations.get("offsetSeconds") is None else str(expectations["offsetSeconds"]),
        "expected_ticks_per_beat": "" if expectations.get("ticksPerBeat") is None else str(expectations["ticksPerBeat"]),
        "expected_time_signature": "",
        "expected_time_signature_numerator": "",
        "expected_time_signature_denominator": "",
        "expected_timing_source": expectations.get("timingSource") or "",
        "audio_root": audio_root or "",
        "audio_path": audio_path or "",
        "audio_resolved_path": str(audio_resolved_path) if audio_resolved_path else "",
    }
    time_signature = expectations.get("timeSignature")
    if time_signature:
        template_vars["expected_time_signature"] = f'{time_signature["numerator"]}/{time_signature["denominator"]}'
        template_vars["expected_time_signature_numerator"] = str(time_signature["numerator"])
        template_vars["expected_time_signature_denominator"] = str(time_signature["denominator"])
    return template_vars


def evaluate_expected_timing(import_payload: Dict[str, Any], expectations: Dict[str, Any]) -> List[Dict[str, Any]]:
    timing = import_payload.get("timing") or {}
    mismatches: List[Dict[str, Any]] = []
    for key, expected_key in (("bpm", "bpm"), ("offsetSeconds", "offsetSeconds"), ("ticksPerBeat", "ticksPerBeat")):
        if expectations.get(expected_key) is None:
            continue
        actual = timing.get(key)
        if actual != expectations[expected_key]:
            mismatches.append({"field": key, "expected": expectations[expected_key], "actual": actual})
    if expectations.get("timeSignature") is not None:
        actual_sig = timing.get("timeSignature") or {}
        if actual_sig != expectations["timeSignature"]:
            mismatches.append({"field": "timeSignature", "expected": expectations["timeSignature"], "actual": actual_sig})
    if expectations.get("timingSource") is not None:
        actual_source = timing.get("source")
        if actual_source != expectations["timingSource"]:
            mismatches.append({"field": "source", "expected": expectations["timingSource"], "actual": actual_source})
    return mismatches


def handler_validate_masterofdrums_chart(args: argparse.Namespace, config: Dict[str, Any], repo_info: Dict[str, Any]) -> Dict[str, Any]:
    validate_validation_mode(args.validation_mode)
    chart_resolved_path = resolve_repo_path(repo_info, args.chart_root, args.chart_path, must_exist=True)
    if not chart_resolved_path.is_file():
        raise AgentError("CHART_NOT_A_FILE", f"Chart path is not a file: {chart_resolved_path}", 22, {"chart_path": args.chart_path})

    audio_resolved_path: Optional[Path] = None
    if args.audio_path:
        audio_root = args.audio_root or "repo"
        audio_resolved_path = resolve_repo_path(repo_info, audio_root, args.audio_path, must_exist=True)
        if not audio_resolved_path.is_file():
            raise AgentError("AUDIO_NOT_A_FILE", f"Audio path is not a file: {audio_resolved_path}", 22, {"audio_path": args.audio_path})
    elif args.audio_root:
        raise AgentError("AUDIO_PATH_REQUIRED", "--audio-root requires --audio-path", 22)

    expectations = {
        "bpm": args.expected_bpm,
        "offsetSeconds": args.expected_offset_seconds,
        "ticksPerBeat": args.expected_ticks_per_beat,
        "timeSignature": parse_time_signature(args.expected_time_signature) if args.expected_time_signature else None,
        "timingSource": args.expected_timing_source,
    }

    validation_cfg = (repo_info["config"].get("app_validation") or {})
    build_recipe = validation_cfg.get("build_recipe")
    import_recipe = validation_cfg.get("import_recipe")
    if not build_recipe:
        raise AgentError("APP_VALIDATION_NOT_CONFIGURED", "masterofdrums app validation build recipe is not configured", 22, {"repo": repo_info["name"]})
    if args.validation_mode != "build-only" and not import_recipe:
        raise AgentError("APP_VALIDATION_NOT_CONFIGURED", "masterofdrums app validation import recipe is not configured", 22, {"repo": repo_info["name"]})

    sync = run_git_sync(repo_info, args.branch, args.expected_commit)
    template_vars = build_masterofdrums_template_vars(
        repo_info,
        chart_root=args.chart_root,
        chart_path=args.chart_path,
        chart_resolved_path=chart_resolved_path,
        audio_root=args.audio_root,
        audio_path=args.audio_path,
        audio_resolved_path=audio_resolved_path,
        validation_mode=args.validation_mode,
        expectations=expectations,
    )

    build_argv = render_template_list(build_recipe["argv"], repo_info, template_vars)
    build_env = render_template_map(build_recipe.get("env") or {}, repo_info, template_vars)
    build_timeout = int(build_recipe.get("timeout_seconds", 600))
    build_result = run_subprocess(build_argv, repo_info=repo_info, timeout=build_timeout, extra_env=build_env)
    build_payload = {
        "status": "pass" if build_result["status"] == 0 else "fail",
        "details": build_result["stdout"] or build_result["stderr"],
        "stdout": build_result["stdout"],
        "stderr": build_result["stderr"],
    }
    if build_result["status"] != 0:
        raise AgentError("BUILD_FAILED", "masterofdrums build failed", build_result["status"], {"build": build_payload})

    import_payload: Dict[str, Any] = {
        "status": "skipped",
        "chart": {"root": args.chart_root, "path": args.chart_path, "resolved_path": str(chart_resolved_path)},
        "audio": None if not audio_resolved_path else {"root": args.audio_root or "repo", "path": args.audio_path, "resolved_path": str(audio_resolved_path)},
        "timingContractVersion": None,
        "timing": {},
        "stdout": "",
        "stderr": "",
    }
    authority_checks = {
        "generatedTimingAuthoritative": None,
        "audioDetectionDiagnosticOnly": None,
        "manualOverrideExplicit": None,
        "timeSignatureRespected": None,
    }
    ui_observations: List[str] = []
    artifacts = {"screenshots": [], "logs": [], "xcresult": None}
    errors: List[Dict[str, Any]] = []

    if args.validation_mode != "build-only":
        import_argv = render_template_list(import_recipe["argv"], repo_info, template_vars)
        import_env = render_template_map(import_recipe.get("env") or {}, repo_info, template_vars)
        import_timeout = int(import_recipe.get("timeout_seconds", 300))
        import_result = run_subprocess(import_argv, repo_info=repo_info, timeout=import_timeout, extra_env=import_env)
        import_payload["status"] = "pass" if import_result["status"] == 0 else "fail"
        import_payload["stdout"] = import_result["stdout"]
        import_payload["stderr"] = import_result["stderr"]
        parsed_import = parse_json_if_possible(import_result["stdout"])
        if isinstance(parsed_import, dict):
            import_payload["timingContractVersion"] = parsed_import.get("timingContractVersion")
            import_payload["timing"] = parsed_import.get("timing") or {}
            authority_checks.update(parsed_import.get("authorityChecks") or {})
            ui_observations = parsed_import.get("uiObservations") or []
            parsed_artifacts = parsed_import.get("artifacts") or {}
            if isinstance(parsed_artifacts, dict):
                artifacts.update(parsed_artifacts)
        if import_result["status"] != 0:
            raise AgentError("CHART_IMPORT_FAILED", "masterofdrums chart validation failed", import_result["status"], {"import": import_payload})

        mismatches = evaluate_expected_timing(import_payload, expectations)
        if mismatches:
            errors.extend({"code": "EXPECTED_TIMING_MISMATCH", "details": item} for item in mismatches)

    status = "pass"
    if errors:
        status = "fail"
    elif args.validation_mode != "build-only" and import_payload["status"] != "pass":
        status = "fail"

    return {
        "status": status,
        "repo": repo_info["name"],
        "validation_mode": args.validation_mode,
        "sync": {key: sync[key] for key in ("branch", "expected_commit", "resolved_commit", "head")},
        "build": build_payload,
        "import": import_payload,
        "expectations": expectations,
        "authorityChecks": authority_checks,
        "uiObservations": ui_observations,
        "artifacts": artifacts,
        "errors": errors,
    }


def run_dir_status_path(run_dir: Path) -> Path:
    return run_dir / "status.json"


def read_status_file(run_dir: Path) -> Dict[str, Any]:
    status_path = run_dir_status_path(run_dir)
    if not status_path.exists():
        raise AgentError("RUN_NOT_FOUND", f"Run status not found: {status_path}", 22, {"run_dir": str(run_dir)})
    return json.loads(status_path.read_text(encoding="utf-8"))


def write_status_file(run_dir: Path, payload: Dict[str, Any]) -> None:
    run_dir.mkdir(parents=True, exist_ok=True)
    run_dir_status_path(run_dir).write_text(json.dumps(payload, separators=(",", ":")), encoding="utf-8")


def handler_run_pipeline(args: argparse.Namespace, config: Dict[str, Any], repo_info: Dict[str, Any]) -> Dict[str, Any]:
    profiles = (repo_info["config"].get("pipeline_profiles") or {})
    if args.profile not in profiles:
        raise AgentError("UNKNOWN_PROFILE", f"Unknown pipeline profile: {args.profile}", 22, {"profile": args.profile})
    recipe = profiles[args.profile]
    recipe = dict(recipe)
    recipe["name"] = args.profile
    resolved_source_uri, source_path, resolved_source_name = resolve_source_input(
        repo_info,
        source_uri=args.source_uri,
        source_name=getattr(args, "source_name", None),
        sample_set=getattr(args, "sample_set", None),
        profile=recipe,
    )

    run_id = f"{datetime.now(timezone.utc).strftime('%Y%m%d-%H%M%S')}-{uuid.uuid4().hex[:6]}"
    run_dir = repo_info["roots"]["runs"] / run_id
    run_dir.mkdir(parents=True, exist_ok=True)
    stdout_log = run_dir / "stdout.log"
    stderr_log = run_dir / "stderr.log"
    template_vars = {
        "source_uri": resolved_source_uri,
        "source_path": str(source_path),
        "source_name": resolved_source_name,
        "run_dir": str(run_dir),
    }
    argv = render_template_list(recipe["argv"], repo_info, template_vars)
    recipe_env = render_template_map(recipe.get("env") or {}, repo_info, template_vars)
    timeout = int(recipe.get("timeout_seconds", 600))
    child_env = build_env(repo_info, run_dir, recipe_env)
    child_env["OPENCLAW_MAC_AGENT_CONFIG"] = str(config["_config_path"])

    status_payload = {
        "run_id": run_id,
        "repo": repo_info["name"],
        "profile": args.profile,
        "source_uri": resolved_source_uri,
        "source_name": resolved_source_name or None,
        "status": "running",
        "started_at": utc_now(),
        "finished_at": None,
        "duration_ms": None,
        "exit_code": None,
        "run_dir": str(run_dir),
        "stdout_log": str(stdout_log),
        "stderr_log": str(stderr_log),
        "timeout_seconds": timeout,
    }
    write_status_file(run_dir, status_payload)

    helper_argv = [
        sys.executable,
        str(Path(__file__).resolve()),
        "__run-profile",
        "--config",
        str(config["_config_path"]),
        "--repo",
        repo_info["name"],
        "--run-id",
        run_id,
        "--profile",
        args.profile,
        "--source-uri",
        resolved_source_uri,
    ]
    with stdout_log.open("a", encoding="utf-8") as stdout_handle, stderr_log.open("a", encoding="utf-8") as stderr_handle:
        process = subprocess.Popen(
            helper_argv,
            cwd=str(repo_info["path"]),
            env=child_env,
            stdout=stdout_handle,
            stderr=stderr_handle,
            start_new_session=True,
        )

    status_payload["pid"] = process.pid
    write_status_file(run_dir, status_payload)
    return {
        "repo": repo_info["name"],
        "run": {
            "run_id": run_id,
            "profile": args.profile,
            "source_uri": resolved_source_uri,
            "source_name": resolved_source_name or None,
            "started_at": status_payload["started_at"],
            "finished_at": None,
            "duration_ms": None,
            "exit_code": None,
            "status": "running",
        },
        "paths": {
            "run_dir": str(run_dir),
            "stdout_log": str(stdout_log),
            "stderr_log": str(stderr_log),
        },
        "artifacts": [],
    }


def internal_run_profile(args: argparse.Namespace) -> int:
    config = load_config(args.config)
    repo_info = parse_repo(config, args.repo)
    profiles = (repo_info["config"].get("pipeline_profiles") or {})
    recipe = profiles[args.profile]
    run_dir = repo_info["roots"]["runs"] / args.run_id
    template_vars = {"source_uri": args.source_uri, "source_path": str(ensure_file_uri(args.source_uri)), "run_dir": str(run_dir)}
    argv = render_template_list(recipe["argv"], repo_info, template_vars)
    recipe_env = render_template_map(recipe.get("env") or {}, repo_info, template_vars)
    timeout = int(recipe.get("timeout_seconds", 600))
    start_time = time.time()

    try:
        executable = resolve_executable(argv[0], repo_info)
        argv = [str(executable), *argv[1:]]
        process = subprocess.run(
            argv,
            cwd=str(repo_info["path"]),
            env=build_env(repo_info, run_dir, recipe_env),
            timeout=timeout,
            check=False,
        )
        status_payload = read_status_file(run_dir)
        status_payload["status"] = "completed" if process.returncode == 0 else "failed"
        status_payload["finished_at"] = utc_now()
        status_payload["duration_ms"] = int((time.time() - start_time) * 1000)
        status_payload["exit_code"] = process.returncode
        status_payload["artifacts"] = parse_summary_artifacts(run_dir)
        write_status_file(run_dir, status_payload)
        return process.returncode
    except AgentError as exc:
        status_payload = read_status_file(run_dir)
        status_payload["status"] = "failed"
        status_payload["finished_at"] = utc_now()
        status_payload["duration_ms"] = int((time.time() - start_time) * 1000)
        status_payload["exit_code"] = exc.exit_code
        status_payload["error"] = {"code": exc.code, "message": exc.message, "details": exc.details}
        status_payload["artifacts"] = parse_summary_artifacts(run_dir)
        write_status_file(run_dir, status_payload)
        return exc.exit_code


def handler_get_run_status(args: argparse.Namespace, config: Dict[str, Any], repo_info: Dict[str, Any]) -> Dict[str, Any]:
    run_dir = resolve_repo_path(repo_info, "runs", args.run_id, must_exist=True)
    status_payload = read_status_file(run_dir)
    return {
        "repo": repo_info["name"],
        "run": status_payload,
    }


def ensure_clean_tree(repo_info: Dict[str, Any]) -> None:
    if repo_status_lines(repo_info):
        raise AgentError("CLEAN_TREE_REQUIRED", "Repository must be clean for this operation", 22, {"repo": repo_info["name"]})


def handler_git_fetch(args: argparse.Namespace, config: Dict[str, Any], repo_info: Dict[str, Any]) -> Dict[str, Any]:
    result = run_subprocess(["git", "fetch", "--prune"], repo_info=repo_info, timeout=30)
    return {
        "repo": repo_info["name"],
        "git": {"operation": "fetch", "exit_code": result["status"]},
        "stdout": result["stdout"],
        "stderr": result["stderr"],
    }


def handler_git_pull(args: argparse.Namespace, config: Dict[str, Any], repo_info: Dict[str, Any]) -> Dict[str, Any]:
    if not args.ff_only:
        raise AgentError("FF_ONLY_REQUIRED", "git-pull requires --ff-only", 22)
    ensure_clean_tree(repo_info)
    result = run_subprocess(["git", "pull", "--ff-only"], repo_info=repo_info, timeout=30)
    return {
        "repo": repo_info["name"],
        "git": {"operation": "pull", "mode": "ff-only", "exit_code": result["status"]},
        "stdout": result["stdout"],
        "stderr": result["stderr"],
    }


def handler_git_sync(args: argparse.Namespace, config: Dict[str, Any], repo_info: Dict[str, Any]) -> Dict[str, Any]:
    sync = run_git_sync(repo_info, args.branch, args.expected_commit)
    return {
        "repo": repo_info["name"],
        "git": {key: sync[key] for key in ("operation", "branch", "expected_commit", "resolved_commit", "head", "exit_code")},
        "stdout": sync["stdout"],
        "stderr": sync["stderr"],
    }


HANDLERS = {
    "env-check": handler_env_check,
    "repo-status": handler_repo_status,
    "resolve-sources": handler_resolve_sources,
    "read-file": handler_read_file,
    "tail-file": handler_tail_file,
    "list-artifacts": handler_list_artifacts,
    "summarize-artifact": handler_summarize_artifact,
    "validate-analyzer": handler_validate_analyzer,
    "validate-masterofdrums-chart": handler_validate_masterofdrums_chart,
    "run-pipeline": handler_run_pipeline,
    "get-run-status": handler_get_run_status,
    "git-fetch": handler_git_fetch,
    "git-pull": handler_git_pull,
    "git-sync": handler_git_sync,
}


def build_parser() -> argparse.ArgumentParser:
    parser = argparse.ArgumentParser(prog="openclaw-mac-agent")
    parser.add_argument("--config", default=os.environ.get("OPENCLAW_MAC_AGENT_CONFIG"))
    subparsers = parser.add_subparsers(dest="verb", required=True)

    parser_env = subparsers.add_parser("env-check")
    parser_env.add_argument("--repo", required=True)
    parser_env.add_argument("--json", action="store_true")

    parser_status = subparsers.add_parser("repo-status")
    parser_status.add_argument("--repo", required=True)
    parser_status.add_argument("--json", action="store_true")

    parser_sources = subparsers.add_parser("resolve-sources")
    parser_sources.add_argument("--repo", required=True)
    parser_sources.add_argument("--profile")
    parser_sources.add_argument("--source-uri")
    parser_sources.add_argument("--source-name")
    parser_sources.add_argument("--sample-set")
    parser_sources.add_argument("--json", action="store_true")

    parser_read = subparsers.add_parser("read-file")
    parser_read.add_argument("--repo", required=True)
    parser_read.add_argument("--root", default="repo")
    parser_read.add_argument("--path", required=True)
    parser_read.add_argument("--max-bytes", type=int, default=32768)
    parser_read.add_argument("--json", action="store_true")

    parser_tail = subparsers.add_parser("tail-file")
    parser_tail.add_argument("--repo", required=True)
    parser_tail.add_argument("--root", default="logs")
    parser_tail.add_argument("--path", required=True)
    parser_tail.add_argument("--lines", type=int, default=200)
    parser_tail.add_argument("--json", action="store_true")

    parser_list = subparsers.add_parser("list-artifacts")
    parser_list.add_argument("--repo", required=True)
    parser_list.add_argument("--root", default="artifacts")
    parser_list.add_argument("--path", default="")
    parser_list.add_argument("--json", action="store_true")

    parser_summary = subparsers.add_parser("summarize-artifact")
    parser_summary.add_argument("--repo", required=True)
    parser_summary.add_argument("--root", default="repo")
    parser_summary.add_argument("--path", required=True)
    parser_summary.add_argument("--json", action="store_true")

    parser_validate = subparsers.add_parser("validate-analyzer")
    parser_validate.add_argument("--repo", required=True)
    parser_validate.add_argument("--profile")
    parser_validate.add_argument("--source-uri")
    parser_validate.add_argument("--source-name")
    parser_validate.add_argument("--sample-set")
    parser_validate.add_argument("--json", action="store_true")

    parser_master = subparsers.add_parser("validate-masterofdrums-chart")
    parser_master.add_argument("--repo", required=True)
    parser_master.add_argument("--branch", required=True)
    parser_master.add_argument("--expected-commit", required=True)
    parser_master.add_argument("--chart-root", required=True)
    parser_master.add_argument("--chart-path", required=True)
    parser_master.add_argument("--validation-mode", required=True)
    parser_master.add_argument("--audio-root")
    parser_master.add_argument("--audio-path")
    parser_master.add_argument("--expected-bpm", type=float)
    parser_master.add_argument("--expected-offset-seconds", type=float)
    parser_master.add_argument("--expected-ticks-per-beat", type=int)
    parser_master.add_argument("--expected-time-signature")
    parser_master.add_argument("--expected-timing-source")
    parser_master.add_argument("--json", action="store_true")

    parser_run = subparsers.add_parser("run-pipeline")
    parser_run.add_argument("--repo", required=True)
    parser_run.add_argument("--source-uri")
    parser_run.add_argument("--source-name")
    parser_run.add_argument("--sample-set")
    parser_run.add_argument("--profile", required=True)
    parser_run.add_argument("--json", action="store_true")

    parser_run_status = subparsers.add_parser("get-run-status")
    parser_run_status.add_argument("--repo", required=True)
    parser_run_status.add_argument("--run-id", required=True)
    parser_run_status.add_argument("--json", action="store_true")

    parser_fetch = subparsers.add_parser("git-fetch")
    parser_fetch.add_argument("--repo", required=True)
    parser_fetch.add_argument("--json", action="store_true")

    parser_pull = subparsers.add_parser("git-pull")
    parser_pull.add_argument("--repo", required=True)
    parser_pull.add_argument("--ff-only", action="store_true", required=False)
    parser_pull.add_argument("--json", action="store_true")

    parser_sync = subparsers.add_parser("git-sync")
    parser_sync.add_argument("--repo", required=True)
    parser_sync.add_argument("--branch", required=True)
    parser_sync.add_argument("--expected-commit", required=True)
    parser_sync.add_argument("--json", action="store_true")

    internal = subparsers.add_parser("__run-profile")
    internal.add_argument("--repo", required=True)
    internal.add_argument("--run-id", required=True)
    internal.add_argument("--profile", required=True)
    internal.add_argument("--source-uri", required=True)
    internal.add_argument("--config", required=True)

    return parser


def main() -> int:
    parser = build_parser()
    args = parser.parse_args()

    if args.verb == "__run-profile":
        return internal_run_profile(args)

    if args.verb not in PUBLIC_VERBS:
        raise AgentError("UNKNOWN_VERB", f"Unknown verb: {args.verb}", 22, {"verb": args.verb})

    started_at = time.time()
    request_id = make_request_id()
    agent_home = Path(os.environ.get("OPENCLAW_MAC_AGENT_HOME", DEFAULT_AGENT_HOME)).expanduser()

    try:
        config = load_config(args.config)
        repo_info = parse_repo(config, args.repo)
        data = HANDLERS[args.verb](args, config, repo_info)
        payload = response_envelope(
            ok=True,
            verb=args.verb,
            request_id=request_id,
            exit_code=0,
            started_at=started_at,
            data=data,
        )
        emit_json(payload)
        audit_log(agent_home, {
            "ts": utc_now(),
            "request_id": request_id,
            "caller": os.environ.get("SSH_CONNECTION", "local"),
            "verb": args.verb,
            "repo": args.repo,
            "exit_code": 0,
            "duration_ms": payload["duration_ms"],
            "timed_out": False,
        })
        return 0
    except AgentError as exc:
        payload = response_envelope(
            ok=False,
            verb=getattr(args, "verb", "unknown"),
            request_id=request_id,
            exit_code=exc.exit_code,
            started_at=started_at,
            data=None,
            error={"code": exc.code, "message": exc.message, "details": exc.details},
        )
        emit_json(payload)
        audit_log(agent_home, {
            "ts": utc_now(),
            "request_id": request_id,
            "caller": os.environ.get("SSH_CONNECTION", "local"),
            "verb": getattr(args, "verb", "unknown"),
            "repo": getattr(args, "repo", None),
            "exit_code": exc.exit_code,
            "duration_ms": payload["duration_ms"],
            "timed_out": exc.code == "TIMEOUT",
            "error": {"code": exc.code, "message": exc.message},
        })
        return exc.exit_code


if __name__ == "__main__":
    sys.exit(main())
