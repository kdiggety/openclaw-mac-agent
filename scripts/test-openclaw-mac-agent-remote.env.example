# Copy to a local, untracked file such as:
#   cp scripts/test-openclaw-mac-agent-remote.env.example scripts/test-openclaw-mac-agent-remote.env
# Then load it before running the remote smoke test:
#   set -a
#   source scripts/test-openclaw-mac-agent-remote.env
#   set +a
#   bash ./scripts/test-openclaw-mac-agent-remote.sh

MAC_HOST=openclaw-agent@192.168.1.156
MAC_SSH_KEY=~/.ssh/openclaw_mac_agent
MAC_AGENT_REPO=masterofdrums-pipeline

# The smoke script reads one tail target so it can prove the remote wrapper
# can access logs through a named root. Update these to match a real file in
# your repo before running the remote test.
MAC_AGENT_LOG_ROOT=logs
MAC_AGENT_LOG_PATH=pipeline.log
